# Server Configuration
PORT=4000
NODE_ENV=production

# MongoDB Configuration (required)
MONGO_USER=your_mongo_username
MONGO_PASS=your_mongo_password
MONGO_HOST=your_cluster.mongodb.net
MONGO_DB=chit

# Alternative: Full MongoDB URI (use this OR the above separate fields)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# JWT Secret (required - generate a strong random string)
JWT_SECRET=your_very_secure_random_jwt_secret_key_here

# Frontend URL (required - your Vercel deployment URL)
CLIENT_ORIGIN=https://your-app.vercel.app

# Backend public URL (optional but recommended for email links)
# When set, verification/reset links will point directly to API.
# Example for Render/Railway/Heroku: https://your-api.onrender.com
# Example for local dev: http://localhost:4000
API_ORIGIN=

# DB / API Performance Tuning
# Connection pool sizes for Mongo driver under traffic spikes
DB_MAX_POOL_SIZE=40
DB_MIN_POOL_SIZE=5
DB_SERVER_SELECTION_TIMEOUT_MS=10000
DB_SOCKET_TIMEOUT_MS=45000
# Leave empty to auto-manage by environment (true in dev, false in prod)
DB_AUTO_INDEX=
# Log only APIs slower than this threshold (milliseconds)
SLOW_API_THRESHOLD_MS=300

# Redis (optional but recommended for scaling and faster room cache reads)
# Example local: redis://127.0.0.1:6379
# Example managed TLS: rediss://:password@your-host:6380
REDIS_URL=
# Set false to force-disable Redis even if REDIS_URL is set
REDIS_ENABLED=true
# Max reconnect retries before graceful fallback to Mongo/in-memory mode
REDIS_MAX_RECONNECT_RETRIES=6
# Keep room cache short-lived on small plans (recommended for 30MB Redis)
REDIS_ROOM_CACHE_TTL_SECONDS=20
# Limit in-process room cache entries to prevent local RAM growth
ROOM_CACHE_MAX_ENTRIES=400
# Skip caching very large docs in Redis (bytes)
REDIS_CACHE_MAX_PAYLOAD_BYTES=65536
# If Redis OOM happens, remove old room cache keys in small batches
REDIS_CACHE_CLEANUP_DELETE_LIMIT=200
# Cache for /rooms listing endpoint (short TTL for freshness + speed)
ROOMS_LIST_CACHE_TTL_SECONDS=5
ROOMS_LIST_CACHE_MAX_ENTRIES=800
# Online users DB snapshot cache to reduce repeated reads under traffic
ONLINE_USERS_CACHE_TTL_SECONDS=8
# /users/batch profile hydration cache and request cap
USERS_BATCH_CACHE_TTL_SECONDS=12
USERS_BATCH_MAX_IDS=50
USERS_BATCH_LOCAL_CACHE_MAX_ENTRIES=220

# Message retention (DB): keep only latest N messages per room/DM
MESSAGE_RETENTION_LIMIT=50
# Max old docs deleted in one prune pass
MESSAGE_PRUNE_BATCH_SIZE=500
# Minimum gap between prune passes per room (ms)
MESSAGE_PRUNE_MIN_INTERVAL_MS=5000

# Cloudinary Configuration (required for file uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
VITE_CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_DEFAULT_FOLDER=chit

# Image moderation (Python CV / AI service) for chat image safety
# Set IMAGE_MODERATION_ENABLED=true after IMAGE_MODERATION_SERVICE_URL is configured.
IMAGE_MODERATION_ENABLED=false
IMAGE_MODERATION_SERVICE_URL=
IMAGE_MODERATION_API_KEY=
IMAGE_MODERATION_TIMEOUT_MS=4500
# true = allow image when moderation service is down, false = block image if service fails
IMAGE_MODERATION_FAIL_OPEN=true
IMAGE_MODERATION_THRESHOLD=0.72
IMAGE_MODERATION_BLOCKED_LABELS=adult,nsfw,porn,hentai,nudity,sexual,sexy,violence,blood,gore,graphic,weapon,harassment,abuse,hate

# SMTP Configuration (optional - for email features)
SMTP_ENABLED=false
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=noreply@zoktu.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_SECURE=false
EMAIL_FROM="ChitZ Support <noreply@zoktu.com>"

# Web Push Notifications (required for native-like PWA push)
# Generate with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=your_web_push_public_key
WEB_PUSH_PRIVATE_KEY=your_web_push_private_key
WEB_PUSH_SUBJECT=mailto:noreply@zoktu.com

# Gemini Bot (optional)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
BOT_NAME=Baka
BOT_ID=bot-baka
BOT_ENABLED=true
BOT_REPLY_COOLDOWN_MS=6000
