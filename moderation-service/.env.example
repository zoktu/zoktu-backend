APP_NAME=ChitZ Image Moderation Service
APP_ENV=development

# Optional auth token expected by this service.
# Backend can send this in either Authorization: Bearer <token> or x-api-key header.
MODERATION_API_KEY=

DEFAULT_THRESHOLD=0.72
BLOCKED_LABELS=adult,nsfw,porn,hentai,nudity,sexual,sexy,violence,blood,gore,graphic,weapon,harassment,abuse,hate

REQUEST_TIMEOUT_SECONDS=8
MAX_IMAGE_MB=12
MAX_IMAGE_PIXELS=16000000

ENABLE_NSFW_MODEL=true
ENABLE_ZERO_SHOT_MODEL=true
NSFW_MODEL_ID=Falconsai/nsfw_image_detection
ZERO_SHOT_MODEL_ID=openai/clip-vit-base-patch32

# -1 = CPU, 0 = first CUDA GPU
HF_DEVICE=-1
